# ------------------------------------------------------------------
# Shared environment for the X-ray data collection platform.
# Copy to ".env" and adjust. NEVER commit the real .env file.
# ------------------------------------------------------------------

# --- PostgreSQL ---------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=xray
POSTGRES_PASSWORD=change_me_use_a_strong_password
POSTGRES_DB=xray

# Connection string used by Prisma (API). Keep in sync with the values above.
DATABASE_URL=postgresql://xray:change_me_use_a_strong_password@127.0.0.1:5432/xray?schema=public

# --- API ----------------------------------------------------------
API_PORT=4000

# --- Dashboard ----------------------------------------------------
# Public URL the browser uses to reach the API. On the Pi itself this is
# usually the LAN IP, e.g. http://192.168.1.50:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Storage ------------------------------------------------------
# Path to the SSD-backed storage root. Relative paths are resolved from the
# repo root, so ./storage is portable across development machines and the Pi.
STORAGE_ROOT=./storage

# --- Crawler worker ----------------------------------------------
# Politeness / safety settings for the crawler.
CRAWLER_CONCURRENCY=4
CRAWLER_REQUEST_DELAY_MS=1500
CRAWLER_USER_AGENT=XrayResearchCollector/1.0 (+contact: you@example.com)
CRAWLER_MAX_PAGES_PER_DOMAIN=500
CRAWLER_RESPECT_ROBOTS=true
# Only crawl domains in this allow-list (comma separated). Empty = allow any
# domain reached from a seed. Strongly recommended to keep this populated.
CRAWLER_ALLOWED_DOMAINS=

# --- Local LLM (optional) ----------------------------------------
# The worker can use a small local LLM (e.g. Gemma) to extract more accurate
# metadata (age, sex, is-pediatric-hand-xray, tags, summary) from page text.
# It NEVER looks at image pixels. If no LLM is available it falls back to a
# deterministic regex extractor.
#
# Provider: auto | ollama | llamacpp | none
#   auto     -> use Ollama if OLLAMA_MODEL is set & reachable, else llama.cpp
#               if LLM_MODEL_PATH is set, else regex.
LLM_PROVIDER=auto

# -- Option A: Ollama (recommended on the Pi) ---------------------
# Install Ollama and pull a small model, e.g.:  ollama pull gemma3:4b
# (see scripts/setup-ollama.sh). Leave OLLAMA_MODEL empty to disable Ollama.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=
# Pi 5 CPU inference is slow; give each request a generous timeout (seconds).
OLLAMA_TIMEOUT=120

# -- Option B: llama.cpp GGUF (alternative to Ollama) -------------
# Absolute path to a Gemma GGUF model. Requires: pip install llama-cpp-python
LLM_MODEL_PATH=
LLM_THREADS=4
LLM_CONTEXT=4096
