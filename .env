# ------------------------------------------------------------------
# Real environment for the X-ray data collection platform (local-only).
# This file is git-ignored. Keep it out of version control.
# ------------------------------------------------------------------

# --- PostgreSQL ---------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=xray
POSTGRES_PASSWORD=070Xwr0vgw2h2bHtBhLfHvKVcWfkjZOI
POSTGRES_DB=xray

# Connection string used by Prisma (API). Kept in sync with the values above.
DATABASE_URL=postgresql://xray:070Xwr0vgw2h2bHtBhLfHvKVcWfkjZOI@127.0.0.1:5432/xray?schema=public

# --- API ----------------------------------------------------------
API_PORT=4000

# --- Dashboard ----------------------------------------------------
# URL the browser uses to reach the API. Use localhost when browsing on the
# Pi itself, or set the Pi's LAN IP (e.g. http://192.168.1.50:4000) to open
# the dashboard from another computer on the network.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Storage ------------------------------------------------------
# Relative paths are resolved from the repo root. On the Pi, you can also
# point this at your SSD mount, e.g. /mnt/ssd/xray-storage
STORAGE_ROOT=./storage

# --- Crawler worker ----------------------------------------------
CRAWLER_CONCURRENCY=4
CRAWLER_REQUEST_DELAY_MS=1500
CRAWLER_USER_AGENT=XrayResearchCollector/1.0 (+contact: you@example.com)
CRAWLER_MAX_PAGES_PER_DOMAIN=500
CRAWLER_MAX_DEPTH=3
CRAWLER_RESPECT_ROBOTS=true
# Only crawl domains in this allow-list (comma separated). Empty = allow any
# domain reached from a seed. Strongly recommended to keep this populated.
CRAWLER_ALLOWED_DOMAINS=

# --- Local LLM (optional) ----------------------------------------
# Absolute path to a Gemma GGUF model. Empty = deterministic regex extractor.
LLM_MODEL_PATH=
LLM_THREADS=4
LLM_CONTEXT=4096
