[Unit]
Description=X-ray Data Collection Dashboard (Next.js)
After=network.target xray-api.service
Wants=xray-api.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/xray-data-collection/apps/dashboard
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
